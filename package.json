{
  "name": "whalliam",
  "version": "0.1.0",
  "description": "An Obsidian plugin that embeds CodeWhale AI agent as a sidebar chat.",
  "description_zh": "将 CodeWhale AI 编码代理嵌入 Obsidian 侧边栏聊天的插件。",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json",
    "lint:fix": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json --fix",
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch"
  },
  "author": {
    "name": "Kasukabe Tsumugi",
    "email": "futami16237@gmail.com"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.25.4",
    "obsidian": "^1.12.3",
    "oxlint": "^1.72.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
