{
  "name": "whalliam",
  "version": "0.1.0",
  "description": "Whalliam - CodeWhale embedded in Obsidian sidebar",
  "main": "main.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "pnpm build:css && node esbuild.config.mjs",
    "build": "node scripts/build.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json",
    "lint:fix": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json --fix",
    "version": "node scripts/sync-version.js && git add manifest.json"
  },
  "keywords": [
    "codewhale",
    "obsidian",
    "obsidian-plugin",
    "productivity",
    "ide"
  ],
  "author": "Kasukabe Tsumugi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.25.4",
    "obsidian": "^1.12.3",
    "oxlint": "^1.72.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "smol-toml": "^1.6.1"
  }
}